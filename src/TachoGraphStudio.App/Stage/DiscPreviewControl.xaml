<UserControl
    x:Class="TachoGraphStudio.App.Stage.DiscPreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer
            x:Name="Scroller"
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Enabled"
            MaxZoomFactor="8"
            MinZoomFactor="1"
            SizeChanged="OnScrollerSizeChanged"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled"
            ZoomMode="Enabled">
            <!-- ビューポートと同サイズに保ち、ZoomFactor=1 が「全体表示」になるようにする -->
            <Grid x:Name="ContentHost">
                <Image
                    x:Name="DiscImage"
                    Margin="12"
                    RenderTransformOrigin="0.5,0.5"
                    SizeChanged="OnDiscImageSizeChanged"
                    Source="{x:Bind Source, Mode=OneWay}"
                    Stretch="Uniform">
                    <Image.RenderTransform>
                        <RotateTransform Angle="{x:Bind Angle, Mode=OneWay}" />
                    </Image.RenderTransform>
                </Image>
                <!-- 文字入れレイヤー(FR-18): 画像の回転と独立し、ズーム・スクロールには追従する -->
                <Canvas
                    x:Name="TextOverlayCanvas"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False" />
                <!-- 十字ガイド(FR-06): 画像の回転とは独立し、ズーム・スクロールには追従する -->
                <Rectangle
                    Height="1"
                    VerticalAlignment="Center"
                    Fill="{ThemeResource AccentFillColorDefaultBrush}"
                    IsHitTestVisible="False"
                    Opacity="0.5" />
                <Rectangle
                    Width="1"
                    HorizontalAlignment="Center"
                    Fill="{ThemeResource AccentFillColorDefaultBrush}"
                    IsHitTestVisible="False"
                    Opacity="0.5" />
            </Grid>
        </ScrollViewer>
        <StackPanel
            Margin="12"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                Click="OnZoomInClick"
                Content="ズーム ＋"
                ToolTipService.ToolTip="ズームイン" />
            <Button
                Click="OnZoomOutClick"
                Content="ズーム −"
                ToolTipService.ToolTip="ズームアウト" />
            <Button
                Click="OnFullscreenClick"
                Content="⤢ 拡大"
                ToolTipService.ToolTip="全画面で拡大表示"
                Visibility="{x:Bind IsFullscreenButtonVisible, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</UserControl>
