<Window
    x:Class="TachoGraphStudio.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid" Loaded="OnRootGridLoaded" RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="*,Auto">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="TachoGraphStudio" />
            <Button
                Grid.Column="1"
                Click="OnOpenSettingsButtonClick"
                Content="設定" />
        </Grid>
        <InfoBar
            x:Name="SupabaseSettingsInfoBar"
            Grid.Row="1"
            Margin="16,0"
            IsClosable="False"
            Message="名簿機能を使うには Supabase の接続設定が必要です。名簿以外の機能は引き続き利用できます。"
            Severity="Warning">
            <InfoBar.ActionButton>
                <Button Click="OnOpenSettingsButtonClick" Content="設定を開く" />
            </InfoBar.ActionButton>
        </InfoBar>
        <Grid Grid.Row="2">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="TachoGraphStudio" />
        </Grid>
    </Grid>
</Window>
