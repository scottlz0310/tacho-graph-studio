<Window
    x:Class="TachoGraphStudio.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:coretemplates="using:TachoGraphStudio.Core.Templates"
    xmlns:stage="using:TachoGraphStudio.App.Stage"
    xmlns:templates="using:TachoGraphStudio.App.Templates"
    xmlns:tv="using:WinUI.TableView">
    <Grid x:Name="RootGrid" Loaded="OnRootGridLoaded" RowDefinitions="Auto,Auto,*">
        <Grid.Resources>
            <Style x:Key="RosterCellTextStyle" TargetType="TextBlock">
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <!-- テンプレート選択 ComboBox 用(#43)。実テンプレートと末尾の編集導線を描き分ける -->
            <DataTemplate x:Key="TemplateSelectionEntryTemplate" x:DataType="coretemplates:StoredTemplate">
                <TextBlock Text="{x:Bind Template.Name}" />
            </DataTemplate>
            <DataTemplate x:Key="TemplateSelectionEditEntryTemplate" x:DataType="stage:TemplateEditEntry">
                <TextBlock
                    FontStyle="Italic"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="テンプレートを編集..." />
            </DataTemplate>
            <stage:TemplateSelectionItemTemplateSelector
                x:Key="TemplateSelectionItemTemplateSelector"
                EditEntryTemplate="{StaticResource TemplateSelectionEditEntryTemplate}"
                TemplateItemTemplate="{StaticResource TemplateSelectionEntryTemplate}" />
        </Grid.Resources>
        <Grid
            Grid.Row="0"
            Padding="16,12"
            ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="16">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="TachoGraphStudio" />
            <!-- 処理対象日・チャート紙様式・手書きスキップ(FR-14, FR-16, FR-17) -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8">
                <TextBlock VerticalAlignment="Center" Text="処理対象日:" />
                <CalendarDatePicker
                    x:Name="TargetDatePicker"
                    DateChanged="OnTargetDatePickerDateChanged"
                    DateFormat="{}{year.full}/{month.integer(2)}/{day.integer(2)}" />
                <TextBlock VerticalAlignment="Center" Text="チャート紙様式:" />
                <!-- 選択が主導線(#43)。編集はドロップダウン最下段の TemplateEditEntry から開く -->
                <ComboBox
                    MinWidth="180"
                    ItemTemplateSelector="{StaticResource TemplateSelectionItemTemplateSelector}"
                    ItemsSource="{x:Bind StageViewModel.TemplateSelectionItems}"
                    PlaceholderText="テンプレート未選択"
                    SelectedItem="{x:Bind StageViewModel.SelectedTemplate, Mode=OneWay}"
                    SelectionChanged="OnTemplateSelectionComboBoxSelectionChanged" />
                <!-- 一括指定で全円盤に適用される(アーキテクチャ §4)。取込済み・以降の取込の両方に反映 -->
                <CheckBox
                    VerticalAlignment="Center"
                    Content="手書きのため自動文字入れをスキップ"
                    IsChecked="{x:Bind StageViewModel.SkipHandwritten, Mode=TwoWay}" />
            </StackPanel>
            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                Spacing="8">
                <Button Click="OnOpenSettingsButtonClick" Content="設定" />
            </StackPanel>
        </Grid>
        <!-- アプリ状態の保存失敗(FR-22)。機能は継続するため警告に留める -->
        <InfoBar
            Grid.Row="1"
            Margin="16,0,16,8"
            IsClosable="True"
            IsOpen="{x:Bind AppStateSaver.HasError, Mode=OneWay}"
            Message="{x:Bind AppStateSaver.LastError, Mode=OneWay}"
            Severity="Warning"
            Title="設定の保存に失敗しました" />
        <Grid Grid.Row="2" Padding="16,0,16,16">
            <Grid.ColumnDefinitions>
                <!-- サイドバー幅はスプリッタで可変(#25)。ウィンドウ状態の永続化は #15 -->
                <ColumnDefinition
                    x:Name="SidebarColumn"
                    MinWidth="240"
                    MaxWidth="720"
                    Width="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition MinWidth="480" Width="*" />
            </Grid.ColumnDefinitions>
            <!-- 名簿サイドバー（UR-01, UR-02） -->
            <Border
                Grid.Column="0"
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="8">
                    <InfoBar
                        Grid.Row="0"
                        IsClosable="True"
                        IsOpen="{x:Bind RosterViewModel.HasFilterSettingsWarning, Mode=OneWay}"
                        Message="{x:Bind RosterViewModel.FilterSettingsWarningMessage, Mode=OneWay}"
                        Severity="Warning" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                        <ComboBox
                            x:Name="SeasonComboBox"
                            MinWidth="140"
                            Header="シーズン"
                            SelectionChanged="OnSeasonComboBoxSelectionChanged">
                            <ComboBoxItem Content="全て" Tag="All" />
                            <ComboBoxItem Content="冬期(除雪)" Tag="Winter" />
                            <ComboBoxItem Content="夏期維持" Tag="Summer" />
                            <ComboBoxItem Content="通年" Tag="YearRound" />
                        </ComboBox>
                        <CheckBox
                            x:Name="TachoTargetsOnlyCheckBox"
                            VerticalAlignment="Bottom"
                            Checked="OnTachoTargetsOnlyCheckBoxCheckedChanged"
                            Content="タコ対象のみ"
                            Unchecked="OnTachoTargetsOnlyCheckBoxCheckedChanged" />
                    </StackPanel>
                    <TextBox
                        Grid.Row="2"
                        PlaceholderText="管理番号・運転者で検索..."
                        Text="{x:Bind RosterViewModel.SearchKeyword, Mode=TwoWay}" />
                    <TextBox
                        x:Name="ControlNumberJumpTextBox"
                        Grid.Row="3"
                        KeyDown="OnControlNumberJumpTextBoxKeyDown"
                        PlaceholderText="管理番号ジャンプ（Enter で選択）"
                        Text="{x:Bind RosterViewModel.ControlNumberJumpText, Mode=TwoWay}" />
                    <Grid Grid.Row="4">
                        <tv:TableView
                            x:Name="RosterDataGrid"
                            AutoGenerateColumns="False"
                            CornerButtonMode="None"
                            HeadersVisibility="Columns"
                            IsReadOnly="True"
                            ItemsSource="{x:Bind RosterViewModel.Entries}"
                            RowDoubleTapped="OnRosterDataGridRowDoubleTapped"
                            SelectedItem="{x:Bind RosterViewModel.SelectedEntry, Mode=TwoWay}"
                            SelectionMode="Single"
                            SelectionUnit="Row"
                            Visibility="{x:Bind RosterViewModel.IsGridVisible, Mode=OneWay}">
                            <tv:TableView.Columns>
                                <tv:TableViewTextColumn
                                    Width="64"
                                    Binding="{Binding ControlNumber}"
                                    CanFilter="False"
                                    CanReorder="False"
                                    CanSort="False"
                                    Header="管理" />
                                <tv:TableViewTextColumn
                                    Width="*"
                                    Binding="{Binding Detail}"
                                    CanFilter="False"
                                    CanReorder="False"
                                    CanSort="False"
                                    ElementStyle="{StaticResource RosterCellTextStyle}"
                                    Header="機械名" />
                                <tv:TableViewTextColumn
                                    Width="*"
                                    Binding="{Binding RegistrationNumber}"
                                    CanFilter="False"
                                    CanReorder="False"
                                    CanSort="False"
                                    ElementStyle="{StaticResource RosterCellTextStyle}"
                                    Header="登録番号" />
                                <tv:TableViewTextColumn
                                    Width="*"
                                    Binding="{Binding Driver}"
                                    CanFilter="False"
                                    CanReorder="False"
                                    CanSort="False"
                                    ElementStyle="{StaticResource RosterCellTextStyle}"
                                    Header="運転者" />
                            </tv:TableView.Columns>
                        </tv:TableView>
                        <ProgressRing
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsActive="{x:Bind RosterViewModel.IsLoading, Mode=OneWay}"
                            Visibility="{x:Bind RosterViewModel.IsLoading, Mode=OneWay}" />
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Visibility="{x:Bind RosterViewModel.IsNotConfiguredStateVisible, Mode=OneWay}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                Text="{x:Bind RosterViewModel.NotConfiguredTitle, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="名簿を利用するには接続設定が必要です。"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <Button
                                HorizontalAlignment="Center"
                                Click="OnOpenSettingsButtonClick"
                                Content="設定を開く" />
                        </StackPanel>
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Visibility="{x:Bind RosterViewModel.IsErrorStateVisible, Mode=OneWay}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{x:Bind RosterViewModel.ErrorMessage, Mode=OneWay}"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <Button
                                HorizontalAlignment="Center"
                                Click="OnRosterRetryButtonClick"
                                Content="再試行" />
                        </StackPanel>
                    </Grid>
                    <TextBlock
                        Grid.Row="5"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind RosterViewModel.DataSourceLabel, Mode=OneWay}"
                        Visibility="{x:Bind RosterViewModel.IsGridVisible, Mode=OneWay}" />
                </Grid>
            </Border>
            <!-- キーボード操作(矢印キー)・AutomationPeer を備えた toolkit GridSplitter を使う -->
            <controls:GridSplitter
                Grid.Column="1"
                Width="16"
                AutomationProperties.Name="名簿サイドバーの幅"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Columns" />
            <!-- ステージ（FR-04, FR-06〜08: サムネイルナビ＋プレビュー＋回転補正） -->
            <Grid
                Grid.Column="2"
                RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto"
                RowSpacing="12">
                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Button
                        Click="OnImportSheetsButtonClick"
                        Content="シート取込（PDF / JPEG）"
                        IsEnabled="{x:Bind StageViewModel.IsImportEnabled, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}" />
                    <ProgressRing
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        IsActive="{x:Bind StageViewModel.IsImporting, Mode=OneWay}"
                        Visibility="{x:Bind StageViewModel.IsImporting, Mode=OneWay}" />
                </StackPanel>
                <InfoBar
                    Grid.Row="1"
                    IsClosable="True"
                    IsOpen="{x:Bind StageViewModel.HasImportError, Mode=OneWay}"
                    Message="{x:Bind StageViewModel.ImportError, Mode=OneWay}"
                    Severity="Error"
                    Title="シート取込に失敗しました" />
                <ListView
                    Grid.Row="2"
                    ItemsSource="{x:Bind StageViewModel.Discs}"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollMode="Enabled"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    SelectedItem="{x:Bind StageViewModel.SelectedDisc, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="stage:DiscWorkItem">
                            <StackPanel
                                Width="96"
                                Padding="4,8"
                                Spacing="4">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Label}" />
                                <Border
                                    Width="72"
                                    Height="72"
                                    HorizontalAlignment="Center"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="4">
                                    <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="Uniform" />
                                </Border>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind StatusLabel, Mode=OneWay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Border
                    Grid.Row="3"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <stage:DiscPreviewControl
                            Angle="{x:Bind StageViewModel.SelectedDisc.RotationAngle, Mode=OneWay, FallbackValue=0}"
                            FullscreenRequested="OnPreviewFullscreenRequested"
                            Metadata="{x:Bind StageViewModel.SelectedDisc.Metadata, Mode=OneWay, FallbackValue={x:Null}}"
                            Source="{x:Bind StageViewModel.SelectedDisc.Preview, Mode=OneWay, FallbackValue={x:Null}}"
                            TextTemplate="{x:Bind StageViewModel.SelectedTemplate.Template, Mode=OneWay, FallbackValue={x:Null}}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="シートを取り込むと円盤のプレビューが表示されます"
                            Visibility="{x:Bind StageViewModel.IsEmptyStateVisible, Mode=OneWay}" />
                    </Grid>
                </Border>
                <!-- 回転補正（FR-07: スライダー・数値入力・リセット） -->
                <Grid
                    Grid.Row="4"
                    ColumnDefinitions="Auto,*,Auto,Auto"
                    ColumnSpacing="12">
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="回転補正:" />
                    <Slider
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsEnabled="{x:Bind StageViewModel.HasSelectedDisc, Mode=OneWay}"
                        Maximum="180"
                        Minimum="-180"
                        StepFrequency="0.5"
                        Value="{x:Bind StageViewModel.SelectedDisc.RotationAngle, Mode=TwoWay, FallbackValue=0}" />
                    <NumberBox
                        Grid.Column="2"
                        MinWidth="110"
                        IsEnabled="{x:Bind StageViewModel.HasSelectedDisc, Mode=OneWay}"
                        Maximum="180"
                        Minimum="-180"
                        SmallChange="0.5"
                        SpinButtonPlacementMode="Compact"
                        Value="{x:Bind StageViewModel.SelectedDisc.RotationAngle, Mode=TwoWay, FallbackValue=0}" />
                    <Button
                        Grid.Column="3"
                        Click="OnResetRotationClick"
                        Content="リセット"
                        IsEnabled="{x:Bind StageViewModel.HasSelectedDisc, Mode=OneWay}" />
                </Grid>
                <!-- メタデータエディタ(FR-13, FR-15): いずれも確定前に手修正できる -->
                <Grid
                    Grid.Row="5"
                    ColumnDefinitions="*,*,*"
                    ColumnSpacing="12">
                    <TextBox
                        Grid.Column="0"
                        Header="印字日付"
                        IsEnabled="{x:Bind StageViewModel.HasSelectedDisc, Mode=OneWay}"
                        Text="{x:Bind StageViewModel.SelectedDisc.Metadata.PrintDate, Mode=TwoWay}" />
                    <TextBox
                        Grid.Column="1"
                        Header="登録番号"
                        IsEnabled="{x:Bind StageViewModel.HasSelectedDisc, Mode=OneWay}"
                        Text="{x:Bind StageViewModel.SelectedDisc.Metadata.RegistrationNumber, Mode=TwoWay}" />
                    <TextBox
                        Grid.Column="2"
                        Header="運転者名（臨時手修正可）"
                        IsEnabled="{x:Bind StageViewModel.HasSelectedDisc, Mode=OneWay}"
                        Text="{x:Bind StageViewModel.SelectedDisc.Metadata.DriverName, Mode=TwoWay}" />
                </Grid>
                <!-- 保存アクションバー(FR-19〜21): ファイル名プレビュー・確定保存して次へ -->
                <StackPanel Grid.Row="6" Spacing="8">
                    <InfoBar
                        IsClosable="True"
                        IsOpen="{x:Bind StageViewModel.HasSaveError, Mode=OneWay}"
                        Message="{x:Bind StageViewModel.SaveError, Mode=OneWay}"
                        Severity="Error" />
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind StageViewModel.SaveTargetLabel, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            Grid.Column="1"
                            Click="OnSelectOutputDirectoryButtonClick"
                            Content="出力先..." />
                        <ProgressRing
                            Grid.Column="2"
                            Width="24"
                            Height="24"
                            VerticalAlignment="Center"
                            IsActive="{x:Bind StageViewModel.IsSaving, Mode=OneWay}"
                            Visibility="{x:Bind StageViewModel.IsSaving, Mode=OneWay}" />
                        <Button
                            Grid.Column="3"
                            Click="OnSaveAndAdvanceButtonClick"
                            Content="確定保存して次へ"
                            IsEnabled="{x:Bind StageViewModel.CanSave, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
        <!-- 全画面拡大プレビュー（FR-08） -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            Visibility="{x:Bind StageViewModel.IsPreviewFullscreen, Mode=OneWay}">
            <stage:DiscPreviewControl
                Margin="24"
                Angle="{x:Bind StageViewModel.SelectedDisc.RotationAngle, Mode=OneWay, FallbackValue=0}"
                IsFullscreenButtonVisible="False"
                Metadata="{x:Bind StageViewModel.SelectedDisc.Metadata, Mode=OneWay, FallbackValue={x:Null}}"
                Source="{x:Bind StageViewModel.SelectedDisc.Preview, Mode=OneWay, FallbackValue={x:Null}}"
                TextTemplate="{x:Bind StageViewModel.SelectedTemplate.Template, Mode=OneWay, FallbackValue={x:Null}}" />
            <Button
                Margin="24"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Click="OnCloseFullscreenPreviewClick"
                Content="閉じる" />
        </Grid>
        <!-- テンプレート編集オーバーレイ(FR-24) -->
        <templates:TemplateEditorOverlay
            x:Name="TemplateEditor"
            Grid.Row="0"
            Grid.RowSpan="3"
            Visibility="{x:Bind TemplateEditorViewModel.IsOpen, Mode=OneWay}" />
    </Grid>
</Window>
